def dls(graph, start, goal, depth_limit):
    visited = []

    def dfs(node, depth):
        visited.append(node)
        print(node, end=" ")

        if node == goal:
            return True

        if depth == depth_limit:
            visited.pop()
            return False

        for neighbor in graph[node]:
            if neighbor not in visited:
                if dfs(neighbor, depth+1):
                    return True

        visited.pop()
        return False

    print(f"\nDepth Limit = {depth_limit}")
    if dfs(start,0):
        print("\nGoal Found")
    else:
        print("\nGoal Not Found")

