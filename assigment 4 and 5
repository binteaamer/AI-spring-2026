# TASK 3 – IDS

def ids(graph, start, goal, max_depth):

    def dls(node, depth, path):
        if depth < 0:
            return False
        path.append(node)

        if node == goal:
            return True

        for neighbor in graph[node]:
            if dls(neighbor, depth-1, path):
                return True

        path.pop()
        return False

    for depth in range(max_depth+1):
        print("\nSearching at Depth:", depth)
        path = []
        if dls(start, depth, path):
            print("Goal Found")
            print("Path:", path)
            return

    print("Goal Not Found")


